# ─────────────────────────────────────────────────────────────────────────────
# CLARA v2.0 — Environment Variables Example
# Copy to .env and customise before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
CLARA_HOST=0.0.0.0
CLARA_PORT=9100

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev — no extra service needed)
CLARA_SQLITE_PATH=/home/clara/.clara/clara.db

# PostgreSQL (recommended for production — comment out SQLITE_PATH if using this)
# CLARA_DATABASE_URL=postgresql://clara:clara_dev_pass@localhost:5432/clara

# ── Redis ─────────────────────────────────────────────────────────────────────
CLARA_REDIS_ENABLED=false
CLARA_REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: change both secrets before deploying to any shared environment
CLARA_JWT_SECRET=dev-jwt-secret-change-me
CLARA_JWT_EXPIRE_MINUTES=1440

# TLS (leave empty for plain HTTP/WS in local dev)
CLARA_TLS_CERT=
CLARA_TLS_KEY=

# ── AI Gateway ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
CLARA_UPLOAD_DIR=/home/clara/.clara/uploads

# ── Docker Compose overrides ──────────────────────────────────────────────────
# These are read by docker-compose.yml; only needed when using Docker
POSTGRES_PASSWORD=clara_dev_pass
